#!/bin/sh
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" \
  "Ce dépôt utilise Git LFS mais 'git-lfs' est introuvable dans le PATH. \
Si vous ne souhaitez plus utiliser Git LFS, supprimez ce fichier."; exit 2; }

TOPLEVEL=$(git rev-parse --show-toplevel)
EXPECTED=$(git config -f "$TOPLEVEL/.lfsconfig" lfs.url 2>/dev/null)
ACTUAL=$(git config lfs.url 2>/dev/null)

if [ -n "$EXPECTED" ] && [ -n "$ACTUAL" ] && [ "$ACTUAL" != "$EXPECTED" ]; then
    printf >&2 "\n  ERREUR : l'URL LFS locale ne correspond pas à celle du dépôt.\n\n"
    printf >&2 "  URL attendue  : %s\n" "$EXPECTED"
    printf >&2 "  URL effective : %s\n" "${ACTUAL:-(non définie)}"
    printf >&2 "\n  Pour corriger : git config --unset lfs.url\n\n"
    exit 1
fi

git lfs pre-push "$@"
